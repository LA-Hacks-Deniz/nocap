# No Cap — Environment Variables
#
# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# Each key is annotated with: which phase needs it, where to get it.
#
# All agents (Claude Code, Devin, the gateway, the council) read from `.env`
# via python-dotenv (Python) or `dotenvy` (Rust).

# ───────────────────────────────────────────────────────────
# PHASE 1 — required for the CLI agent
# ───────────────────────────────────────────────────────────

# Google AI Studio key — used for Gemma 4 + Gemini Flash-Lite (FREE, billing OFF)
# How to get: https://ai.dev → "Get API key" → "Create API key in new project"
# CRITICAL: do NOT enable billing on this project.
GOOGLE_API_KEY=

# ───────────────────────────────────────────────────────────
# PHASE 2 — required for Slack + gateway + storage
# ───────────────────────────────────────────────────────────

# MongoDB Atlas connection string (M0 free tier)
# How to get: cloud.mongodb.com → free M0 cluster (us-east-1) →
#   Network Access → add 0.0.0.0/0 (hackathon) →
#   Database Access → create user → connect → SRV string
MONGODB_URI=

# Slack — bot token from your Slack app
# How to get: api.slack.com/apps → Create New App → From scratch →
#   OAuth & Permissions → Bot Token Scopes: commands, chat:write, chat:write.public,
#   chat:write.customize, files:write → Install to workspace → Bot User OAuth Token
SLACK_BOT_TOKEN=

# Slack — signing secret (verifies webhook authenticity)
# Same Slack app → Basic Information → App Credentials → Signing Secret
SLACK_SIGNING_SECRET=

# ElevenLabs API key — voice generation
# How to get: elevenlabs.io → Profile → API Keys
ELEVENLABS_API_KEY=

# ElevenLabs voice ID — recommend "Sarah" (calm, conversational) or "George" (warm, authoritative)
# Default if unsure: EXAVITQu4vr4xnSDxMaL  (Sarah)
# Alternative:       JBFqnCBsd6RMkjVDRZzb  (George)
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL

# DigitalOcean Gradient AI key — embeddings via OpenAI-compatible API
# How to get: cloud.digitalocean.com → AI/ML → Model Access Keys → Create
# Format: sk-do-v1-...
GRADIENT_API_KEY=

# GitHub Personal Access Token — for fetching PR diffs (avoids 60/hr unauth limit)
# How to get: github.com/settings/tokens → Generate new token (fine-grained recommended) →
#   Repository access: Public repos OR specific private repos →
#   Permissions: Contents (Read), Pull requests (Read)
GITHUB_TOKEN=

# Discord webhook URL — fallback notification channel during demo
# How to get: server settings → Integrations → Webhooks → New Webhook → copy URL
# Optional but recommended for demo redundancy.
DISCORD_WEBHOOK_URL=

# ───────────────────────────────────────────────────────────
# PHASE 2 — provisioned automatically by DigitalOcean App Platform
# ───────────────────────────────────────────────────────────

# Redis URL — DO managed Redis interpolated as ${redis.DATABASE_URL}
# Locally for dev: redis://localhost:6379
REDIS_URL=redis://localhost:6379

# ───────────────────────────────────────────────────────────
# PHASE 3 — frontend deployment
# ───────────────────────────────────────────────────────────

# Vercel deploy token (optional — for CI; otherwise `npx vercel` uses browser auth)
VERCEL_TOKEN=

# ───────────────────────────────────────────────────────────
# Shared / dev convenience
# ───────────────────────────────────────────────────────────

# Logging level for Python council and Rust gateway
RUST_LOG=info
PYTHONUNBUFFERED=1

# Local gateway URL (for the MCP server to reach when running locally)
GATEWAY_URL=http://127.0.0.1:8787
